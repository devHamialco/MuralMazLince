# ENTORNO DE EJECUCIÓN
# Valores válidos: development | test | production
NODE_ENV=development

# SERVIDOR
# Puerto en el que corre Express localmente.
# En Railway.app este valor es inyectado automáticamente por la plataforma.
PORT=3000

# BASE DE DATOS — PostgreSQL
# En desarrollo local: cadena de conexión al contenedor de Docker (docker-compose).
# En Railway.app: Railway inyecta DATABASE_URL automáticamente al provisionar
# el plugin de PostgreSQL; no necesitas definirla manualmente en producción.
DATABASE_URL=postgresql://postgres:password@localhost:5432/mural_maz_lince_dev

# AUTENTICACIÓN — JWT
# Clave secreta para firmar y verificar tokens JWT (cookies HttpOnly).
# En producción debe ser una cadena aleatoria larga (mínimo 32 caracteres).
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Referencia: ADR-04 del SAD v1.3
JWT_SECRET=reemplaza_con_una_clave_secreta_aleatoria_de_minimo_32_chars
JWT_EXPIRATION_HOURS=8

# CLOUDINARY — Almacenamiento persistente de imágenes
# Obtén estos valores desde: https://cloudinary.com/console
# Referencia: ADR-01 del SAD v1.3 / RF-32, RF-33 del SRS v1.4
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=reemplaza_con_tu_api_secret_de_cloudinary

# GOOGLE CLOUD VISION API — Moderación de imágenes (Safe Search)
# Obtén la API key desde: https://console.cloud.google.com
# Límite gratuito: 1,000 unidades/mes. El sistema alertará al 80% del límite.
# Referencia: RF-26 del SRS v1.4 / COMP-07 del SAD v1.3
GOOGLE_CLOUD_VISION_KEY=reemplaza_con_tu_api_key_de_google_cloud_vision

# MODERACIÓN — Perceptual Hashing (dHash)
# Distancia de Hamming máxima para considerar dos imágenes como duplicado.
# Rango recomendado: 8–12. Valor calibrado en pruebas: 10 (sobre 64 bits).
# Ajustable sin modificar código. Referencia: RN-07 del SRS v1.4 / ADR-02 del SAD v1.3
HASH_SIMILARITY_THRESHOLD=10

# MODERACIÓN — Umbral de intención para likes y valoraciones
# Interacciones revertidas en menos de este tiempo (ms) se marcan como
# accidentales y se excluyen de las métricas del emprendedor.
# Valor por defecto: 5000 ms (5 segundos). Referencia: RN-08 del SRS v1.4
INTENT_THRESHOLD_MS=5000

# SISTEMA DE REPORTES Y SHADOWBAN
# Todos los umbrales parametrizados según RN-13 del SRS v1.4 / ADR-05 del SAD v1.3
#
# REPORT_ALERT_THRESHOLD       — Reportes únicos para generar alerta de urgencia (RF-37)
# REPORT_SHADOWBAN_THRESHOLD   — Reportes únicos para activar shadowban automático (RF-38)
# REPORT_SHADOWBAN_HOURS       — Horas de inacción del admin antes del shadowban (RF-38)
# REPORT_SHADOWBAN_MAX_HOURS   — Duración máxima del shadowban antes de restauración (RF-38)
REPORT_ALERT_THRESHOLD=3
REPORT_SHADOWBAN_THRESHOLD=5
REPORT_SHADOWBAN_HOURS=12
REPORT_SHADOWBAN_MAX_HOURS=48

# LÍMITES DEL MODELO DE DATOS
# N = proyectos activos máximos por emprendedor (RN-03 del SRS v1.4)
# M = anuncios activos máximos por proyecto    (RN-04 del SRS v1.4)
# Valores definitivos se confirman en SAD; estos son los valores de referencia.
MAX_ACTIVE_PROJECTS_PER_USER=5
MAX_ACTIVE_ANNOUNCEMENTS_PER_PROJECT=3

# GOOGLE CLOUD VISION — Control de cuota mensual
# El sistema registrará una alerta en el log del servidor cuando el consumo
# mensual alcance este porcentaje del límite gratuito (1,000 unidades/mes).
# Referencia: RGO-02 del PMP v1.4 / COMP-07 del SAD v1.3
VISION_API_MONTHLY_LIMIT=1000
VISION_API_ALERT_PERCENTAGE=80

# CORS — Orígenes permitidos
# En desarrollo: el puerto del servidor de React (Vite o CRA).
# En producción: la URL de Railway.app o el dominio personalizado.
# Referencia: ADR-04 del SAD v1.3 (credentials: true requiere origen explícito)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# URL DE PRODUCCIÓN — Usada para generar el código QR (RF-34)
# En desarrollo apunta a localhost. En producción, a la URL de Railway.app.
# Referencia: RF-34 del SRS v1.4 / COMP-11 del SAD v1.3
APP_PRODUCTION_URL=http://localhost:3000